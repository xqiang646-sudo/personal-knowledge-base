<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description or site.description }}">
  <title>{{ title or site.name }}｜{{ site.shortName }}</title>
  {% if homePage %}
  <link rel="canonical" href="{{ site.publicUrl }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="zh_CN">
  <meta property="og:title" content="不会没关系，我们从第一步开始">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.publicUrl }}">
  <meta property="og:image" content="{{ site.publicUrl }}assets/og-home.png">
  <meta property="og:image:width" content="1731">
  <meta property="og:image:height" content="909">
  <meta property="og:image:alt" content="零基础自动驾驶学习系统：不会没关系，我们从第一步开始">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="不会没关系，我们从第一步开始">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.publicUrl }}assets/og-home.png">
  {% endif %}
  <link rel="icon" href="{{ '/assets/favicon.svg' | siteUrl }}" type="image/svg+xml">
  <link rel="stylesheet" href="{{ '/assets/knowledge.css' | siteUrl }}">
  <link rel="stylesheet" href="{{ '/assets/v2.css' | siteUrl }}">
  <link rel="stylesheet" href="{{ '/assets/cyrus-theme.css' | siteUrl }}">
  {% if homePage %}<link rel="stylesheet" href="{{ '/assets/home-textbook.css' | siteUrl }}">{% endif %}
  {% if math %}
  <script src="{{ '/assets/mathjax-config.js' | siteUrl }}"></script>
  <script id="MathJax-script" defer src="https://cdn.jsdelivr.net/npm/mathjax@4/tex-chtml.js"></script>
  {% endif %}
  {% if diagrams %}
  <script type="module">
    import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11.16.0/dist/mermaid.esm.min.mjs";
    mermaid.initialize({
      startOnLoad: true,
      securityLevel: "strict",
      theme: "base",
      themeVariables: {
        primaryColor: "#ffffff",
        primaryTextColor: "#08090b",
        primaryBorderColor: "#111111",
        secondaryColor: "#e9edf3",
        tertiaryColor: "#f4f6f9",
        lineColor: "#656b76",
        fontFamily: "Inter, Noto Sans SC, system-ui, sans-serif"
      },
      flowchart: { htmlLabels: false, curve: "basis", useMaxWidth: false }
    });
  </script>
  {% endif %}
</head>
<body class="{{ bodyClass or 'portal-body' }}" data-theme="cyrus">
  <a class="skip-link" href="#main-content">跳到主要内容</a>
  {% include "partials/site-header.njk" %}
  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>
  {% include "partials/site-footer.njk" %}
  <script defer src="{{ '/assets/progress.js' | siteUrl }}"></script>
  {% if courseId or reader %}<script defer src="{{ '/assets/reader.js' | siteUrl }}"></script>{% endif %}
  {% if learningUpdatePage %}<script type="module" src="{{ '/assets/learning-update.js' | siteUrl }}"></script>{% endif %}
</body>
</html>
