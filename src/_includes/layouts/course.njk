---
layout: layouts/base.njk
---
{% set currentCourse = curriculum.courses | courseById(courseId) %}
{% set course = currentCourse %}
{% set stage = curriculum.stages | stageById(currentCourse.stage) %}
{% set prerequisites = curriculum.courses | prerequisiteCourses(currentCourse.prerequisites) %}
{% set previousCourse = curriculum.courses | previousAvailableCourse(currentCourse.id) %}
{% set nextCourse = curriculum.courses | nextAvailableCourse(currentCourse.id) %}

<div class="portal-wrap reader-shell" data-pagefind-body>
  <a class="reader-content-skip" href="#lesson-content">跳过目录，进入本课正文</a>
  {% include "partials/book-outline.njk" %}

  <article class="reader-content course-content" id="lesson-content" tabindex="-1" aria-labelledby="lesson-title">
    <header class="course-heading">
      <nav class="course-breadcrumb" aria-label="当前位置">
        <a href="{{ '/guide.html' | siteUrl }}">学习指南</a>
        <span aria-hidden="true">/</span>
        <a href="{{ '/' | siteUrl }}#stage-{{ stage.id }}">{{ stage.code }} {{ stage.title }}</a>
      </nav>
      <div class="course-top">
        <span class="course-order">{{ stage.code }}.{{ currentCourse.order }}</span>
        <span class="tag">{{ course.track }}</span>
        <span class="tag">{{ course.effort }}</span>
      </div>
      <h1 id="lesson-title">{{ course.title }}</h1>
      <p class="lead">{{ course.description }}</p>
      <dl class="course-meta">
        <div><dt>本课问题</dt><dd>{{ course.guidingQuestion }}</dd></div>
        <div><dt>先修</dt><dd>{% if prerequisites.length %}{% for item in prerequisites %}{% if item.url %}<a href="{{ item.url | siteUrl }}">{{ item.title }}</a>{% else %}{{ item.title }}（待建设）{% endif %}{% if not loop.last %}、{% endif %}{% endfor %}{% else %}无硬性先修，从这里开始即可。{% endif %}</dd></div>
      </dl>
      <div class="course-outcome"><strong>本课交付：</strong>{{ course.deliverable }}</div>
    </header>

    {% include "partials/course-learning-cycle.njk" %}

    <div class="course-prose" data-course-prose>
      {{ content | safe }}
    </div>

    <nav class="course-next" aria-label="课程前后导航" data-pagefind-ignore>
      {% if previousCourse %}<a href="{{ previousCourse.url | siteUrl }}"><span>上一课</span><strong>{{ previousCourse.title }}</strong></a>{% else %}<span></span>{% endif %}
      {% if nextCourse %}<a class="next" href="{{ nextCourse.url | siteUrl }}"><span>下一课</span><strong>{{ nextCourse.title }}</strong></a>{% endif %}
    </nav>
  </article>
  {% include "partials/page-outline.njk" %}
</div>
